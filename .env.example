# LLM Provider: ollama, openai, claude, or huggingface
LLM_PROVIDER=ollama

# Ollama Configuration (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI Configuration (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-3.5-turbo

# Claude (Anthropic) Configuration (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_CHAT_MODEL=claude-3-sonnet-20240229

# HuggingFace Configuration (used when LLM_PROVIDER=huggingface)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
HUGGINGFACE_CHAT_MODEL=HuggingFaceH4/zephyr-7b-beta

# Vector Store and Database
VECTOR_DB_PATH=vector_db/faiss_index
APP_DB_PATH=data/app.db
APP_SECRET_KEY=change-this-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DATA_DIR=data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=2
